    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst result = data.results[0];\nconst rows = result.data;\n\nreturn rows.map(row => ({\n  json: {\n    name_en: row.row[0],\n    name_latin: row.row[1]\n  }\n}));"
