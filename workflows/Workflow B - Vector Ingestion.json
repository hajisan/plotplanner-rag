        48
      ],
      "id": "e19700af-2f33-4d10-8a00-63a539b2fd21",
      "name": "Loop planter"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\nconst pages = item.query?.pages || {};\nconst pageKey = Object.keys(pages)[0];\nconst page = pages[pageKey];\nconst extract = page?.extract || '';\nconst name_en = $('Loop planter').item.json.name_en;\nconst name_latin = $('Loop planter').item.json.name_latin;\n\nconst nameMap = {\n  'larkspur': 'Delphinium',\n  'marigold': 'Tagetes',\n  'peppers': 'Capsicum',\n  'turnips and rutabagas': 'Turnip'\n};\n\nif (!extract || extract.length < 50) {\n  return {\n    json: {\n      name_en,\n      name_latin,\n      chunks: [],\n      needs_fallback: true,\n      fallback_search: nameMap[name_en] || name_en\n    }\n  };\n}\n\nconst chunkSize = 500;\nconst overlap = 50;\nconst chunks = [];\nlet start = 0;\n\nwhile (start < extract.length) {\n  const end = Math.min(start + chunkSize, extract.length);\n  chunks.push({\n    text: extract.slice(start, end),\n    index: chunks.length\n  });\n  start += chunkSize - overlap;\n}\n\nreturn {\n  json: {\n    name_en,\n    name_latin,\n    chunks,\n    needs_fallback: false\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        -32
      ],
      "id": "04fd05e4-3207-43b2-bce3-3225db1afb04",
      "name": "Chunk tekst"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\nconst { name_en, name_latin, chunks } = item;\n\nif (!chunks || chunks.length === 0) {\n  return { json: { name_en, status: 'no_chunks' } };\n}\n\nfor (const chunk of chunks) {\n  // Hent embedding fra Ollama\n  const embeddingResponse = await this.helpers.httpRequest({\n    method: 'POST',\n    url: 'http://127.0.0.1:11434/api/embeddings',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({\n      model: 'nomic-embed-text',\n      prompt: chunk.text\n    })\n  });\n\n  const embedding = embeddingResponse.embedding;\n\n  // Skriv chunk + embedding til Neo4j\n  await this.helpers.httpRequest({\n    method: 'POST',\n    url: 'http://127.0.0.1:7474/db/neo4j/tx/commit',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': 'Basic ' + Buffer.from('neo4j:hajiyard2026').toString('base64')\n    },\n    body: JSON.stringify({\n      statements: [{\n        statement: `\n          MATCH (p:Plant {name_en: $name_en})\n          CREATE (c:Chunk {\n            text: $text,\n            index: $index,\n            embedding: $embedding\n          })\n          CREATE (p)-[:HAS_CHUNK]->(c)\n        `,\n        parameters: {\n          name_en,\n          text: chunk.text,\n          index: chunk.index,\n          embedding: embedding\n        }\n      }]\n    })\n  });\n}\n\nreturn { json: { name_en, status: 'ok', chunks_written: chunks.length } };"
      },
